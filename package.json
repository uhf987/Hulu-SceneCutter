{
  "name": "scene-cutter",
  "version": "1.0.0",
  "description": "Fast lossless video scene cutter with smart cut",
  "author": "Scene Cutter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.scenecutter.app",
    "productName": "Scene Cutter",
    "files": [
      "main.js",
      "renderer.js",
      "preload.js",
      "index.html",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffprobe.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signingHashAlgorithms": null,
      "sign": null
    },
    "portable": {
      "artifactName": "SceneCutter-portable.exe"
    }
  },
  "keywords": ["video", "ffmpeg", "lossless", "smart-cut"],
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  }
}
